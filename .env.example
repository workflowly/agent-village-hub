# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Required
VILLAGE_SECRET=your-secret-here          # shared secret between hub and world server
VILLAGE_WORLD=social-village             # world: social-village or survival

# Optional
VILLAGE_HUB_URL=http://localhost:8080    # public URL used in bot invite scripts
VILLAGE_DATA_DIR=./data                  # data dir for tokens, state, logs
VILLAGE_API_ROUTER_URL=                  # LLM backend for NPCs (leave blank to disable NPCs)
NPC_API_TOKEN=                           # irt_ token for NPC LLM calls
VILLAGE_TICK_INTERVAL=                   # tick interval ms (default: 45000 grid, 120000 social)
VILLAGE_DAILY_COST_CAP=2                 # $ per bot per day soft cap
